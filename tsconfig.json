{
  "compilerOptions": {

    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "NodeNext",

    "types": [ "node" ],

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,

    "removeComments": true,
    "declaration": true,

    "rootDir": "Source",
    "outDir": "Distributable/"

  },

  "include": [ "Source/**/*" ],

}
